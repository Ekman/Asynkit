{
  "name": "@nekm/asynkit",
  "version": "1.0.0",
  "description": "Asynkit extends the capabilities of AsyncIterable in JavaScript, providing utility methods such as map, filter, and includes that are natively available for arrays but absent for async iterables.",
  "license": "MIT",
  "types": "./dist/index.d.ts",
  "exports": {
    "types": "./dist/index.d.ts",
    "import": "./dist/index.mjs",
    "require": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "unpkg": "./dist/index.global.js",
  "scripts": {
    "build": "tsup",
    "test": "vitest run"
  },
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "format": [
      "cjs",
      "esm",
      "iife"
    ],
    "dts": true,
    "clean": true
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "maintainers": [
    {
      "email": "niklas@niklasekman.solutions",
      "name": "Niklas Ekman",
      "url": "https://www.niklasekman.solutions"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ekman/Asynkit.git"
  },
  "homepage": "https://github.com/Ekman/Asynkit#readme",
  "files": [
    "dist",
    "src"
  ],
  "author": {
    "name": "Niklas Ekman",
    "email": "niklas@niklasekman.solutions"
  },
  "keywords": [
    "AsyncIterable"
  ],
  "sideEffects": false
}
